# Copy to .env (loaded by your shell / process manager) and adjust as needed.

# HTTP port for the API server.
PORT=8787

# Where all build state lives (Godot sources, worktrees, build cache, queue DB).
# Defaults to ./.data at the repo root.
DATA_ROOT=./.data

# Godot git remote to clone versions from.
GODOT_REPO=https://github.com/godotengine/godot.git

# Platforms every bundle covers (comma-separated subset of: linuxbsd,windows,macos).
# A build is all-or-nothing: the host must have the toolchain for every platform
# listed here or builds are rejected up front. The Docker image ships all three
# (it builds osxcross + installs rcodesign), so its default is all three. On a
# bare host, drop "macos" unless you have osxcross + an Apple SDK + rcodesign on
# PATH (and OSXCROSS_ROOT set). Unset = all three.
# BUILD_PLATFORMS=linuxbsd,windows,macos

# Comma-separated browser origins allowed to call the API (CORS allowlist).
# In production set this to your public origin, e.g. https://nodot.build
CORS_ORIGINS=http://localhost:5173

# Number of reverse proxies in front of the API. When > 0, the real client IP is
# read from X-Forwarded-For (that many hops) so rate limiting keys correctly.
# Set to 1 behind a single nginx/Caddy/Cloudflare; keep 0 when directly exposed.
# TRUST_PROXY=0

# Built web bundle to serve (the API serves it with an SPA fallback). Leave unset
# in dev (use the Vite dev server). In Docker this points at /app/apps/web/dist.
# WEB_DIST=

# Refuse to start a new build when free disk on DATA_ROOT drops below this (GiB).
# Cached downloads keep working; a cold build needs tens of GiB transiently.
MIN_FREE_DISK_GIB=10

# Per-client-IP rate limits (requests per window). The check endpoint fires as
# the user edits options; the build endpoint is expensive so is limited tightly.
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_CHECK=120
# RATE_LIMIT_BUILD=10
# RATE_LIMIT_DOWNLOAD=60

# Per-IP build quota: at most RATE_LIMIT_BUILD_PER_DAY *real* builds (cache hits
# and "server busy" rejections don't count) per RATE_LIMIT_BUILD_WINDOW_MS window
# (default 24h). This is the hard cap on how many builds one IP can trigger.
# RATE_LIMIT_BUILD_PER_DAY=10
# RATE_LIMIT_BUILD_WINDOW_MS=86400000

# Hard cap on total size of published build artifacts (GiB). Oldest builds are
# evicted once this is exceeded.
BUILD_CACHE_LIMIT_GIB=50

# Max simultaneous SSE log streams before new connections are refused.
MAX_SSE_CONNECTIONS=100

# How many builds run concurrently. Native Godot builds are heavy; 1 is safe.
MAX_CONCURRENT_BUILDS=1

# -j value passed to each scons invocation (defaults to CPU core count).
# JOBS_PER_BUILD=8

# Kill a build that exceeds this many milliseconds (default 60 min).
# BUILD_TIMEOUT_MS=3600000

# scons object-cache size cap, in GiB (shared per Godot version).
SCONS_CACHE_LIMIT_GIB=20

# Godot version list is fetched live from the Godot git repo. How long the
# fetched list stays fresh before a background refresh (default 6h).
# VERSIONS_TTL_MS=21600000

# Lowest Godot series offered (the option catalog is tuned for 4.3+).
# VERSIONS_MIN_MAJOR=4
# VERSIONS_MIN_MINOR=3
